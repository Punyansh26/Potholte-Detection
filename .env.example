# Database
# Neon Postgres
DATABASE_URL=postgresql://<user>:<password>@<host>/<database>?sslmode=require&channel_binding=require&connect_timeout=10
# Local fallback:
# DATABASE_URL=sqlite:///./pothole.db
# Docker PostGIS fallback:
# DATABASE_URL=postgresql://pothole:password@localhost:5432/pothole_db

# Storage
STORAGE_PATH=./storage/snapshots

# Grievance
CPGRAMS_ENDPOINT=http://localhost:8000/mock/cpgrams/grievance
RISK_THRESHOLD=80

# Detection
DEFAULT_LAT=19.0760
DEFAULT_LON=72.8777
CAMERA_ID=edge-001
YOLO_MODEL=keremberke/yolov8n-pothole-segmentation
YOLO_CONF=0.25
YOLO_IOU=0.45
YOLO_AGNOSTIC_NMS=false
YOLO_MAX_DET=1000
